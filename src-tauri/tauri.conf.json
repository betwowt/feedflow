{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FeedFlow",
  "version": "1.0.0",
  "identifier": "com.feedflow.rssreader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run start:all",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FeedFlow RSS",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A simple self-hosted RSS reader",
    "longDescription": "FeedFlow is a clean, self-hosted RSS reader with YAML configuration management and proxy support."
  }
}

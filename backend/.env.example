# Lightpanda WebSocket Endpoint
# Get your token at: https://lightpanda.io/
LIGHTPANDA_WS_ENDPOINT=wss://euwest.cloud.lightpanda.io/ws?token=YOUR_TOKEN

# Server Port
PORT=3001

# HTTP/SOCKS Proxy Configuration
# 用于访问需要代理的 RSS 源
# 支持格式：
#   - HTTP 代理: http://host:port
#   - 带认证的 HTTP: http://username:password@host:port
#   - HTTPS 代理: https://host:port
#   - SOCKS5: socks5://host:port 或 socks5://username:password@host:port
#   - SOCKS4: socks4://host:port

# 示例（取消注释并修改为你的代理地址）：
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:1080

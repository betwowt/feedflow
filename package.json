{
  "name": "rss-reader",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "build:backend": "cd backend && npm run build",
    "start": "cd backend && npm run start",
    "start:dev": "cd backend && npx tsx src/server.ts",
    "start:all": "concurrently \"npm run start:dev\" \"npm run dev\""
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  }
}
